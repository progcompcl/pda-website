---
import Page from "@/layouts/Page.astro";
import { YouTube } from '@astro-community/astro-embed-youtube';

import VideosInfo from "@/assets/videos.json";
---

<Page title="Videos Galleries">
  <h2 class="text-center">Videos Gallery</h2>

  <div class="mb-20">
    {
      VideosInfo.map((video) => (
        <div class="mb-10">
          <h4>{video.title}</h4>
          <YouTube
            id={video.youtube_id}
            posterQuality="max" 
            class="rounded-2xl aspect-video w-full"
          />
        </div>
      ))
    }

  </div>

</Page>
